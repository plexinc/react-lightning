{
  "name": "@plextv/react-lightning",
  "version": "0.4.1",
  "description": "React renderer for rendering React apps with Lightning.js",
  "bugs": {
    "url": "https://github.com/plexinc/react-lightning/issues/new"
  },
  "license": "MIT",
  "author": "Plex Inc.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plexinc/react-lightning.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json",
    "./jsx": "./src/types/jsx.d.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.js",
      "./package.json": "./package.json",
      "./jsx": "./dist/types/jsx.d.ts"
    },
    "provenance": true
  },
  "scripts": {
    "build": "tsdown --config-loader unrun",
    "watch": "tsdown -w",
    "clean": "del ./dist",
    "check:types": "tsc --noEmit",
    "test:unit": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "react-reconciler": "0.33.0",
    "tseep": "catalog:"
  },
  "devDependencies": {
    "@repo/configs": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-reconciler": "catalog:",
    "type-fest": "catalog:"
  },
  "peerDependencies": {
    "@lightningjs/renderer": "catalog:",
    "react": "catalog:"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "inlinedDependencies": {
    "type-fest": "5.5.0"
  }
}
