{
  "name": "@plextv/react-lightning-components",
  "version": "0.4.3",
  "description": "React components for react-lightning",
  "bugs": {
    "url": "https://github.com/plexinc/react-lightning/issues/new"
  },
  "license": "MIT",
  "author": "Plex Inc.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plexinc/react-lightning.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./src/index.ts",
    "./layout/Column": "./src/exports/layout/Column.tsx",
    "./layout/Row": "./src/exports/layout/Row.tsx",
    "./lists/VirtualList": "./src/exports/lists/VirtualList.tsx",
    "./text/StyledText": "./src/exports/text/StyledText.tsx",
    "./util/FPSMonitor": "./src/exports/util/FPSMonitor.tsx",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.js",
      "./layout/Column": "./dist/exports/layout/Column.js",
      "./layout/Row": "./dist/exports/layout/Row.js",
      "./lists/VirtualList": "./dist/exports/lists/VirtualList.js",
      "./text/StyledText": "./dist/exports/text/StyledText.js",
      "./util/FPSMonitor": "./dist/exports/util/FPSMonitor.js",
      "./package.json": "./package.json"
    },
    "provenance": true
  },
  "scripts": {
    "build": "tsdown --config-loader unrun",
    "build:watch": "tsdown -w",
    "clean": "del ./dist",
    "check:types": "tsc --noEmit",
    "test:unit": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "@repo/configs": "workspace:*",
    "@types/react": "catalog:"
  },
  "peerDependencies": {
    "@plextv/react-lightning": "workspace:^",
    "@plextv/react-lightning-plugin-flexbox": "workspace:^",
    "react": "catalog:"
  },
  "volta": {
    "extends": "../../package.json"
  }
}
